# =============================================================================
# Musically — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to version control. It is already in .gitignore.
# =============================================================================

# ---------------------------------------------------------------------------
# General
# ---------------------------------------------------------------------------

# Application environment: "development" or "production"
ENVIRONMENT=production

# Log level: "debug", "info", "warning", "error"
LOG_LEVEL=info

# Secret key for encrypting sensitive settings at rest (e.g., API tokens in DB).
# Generate a strong random string: `openssl rand -hex 32`
SECRET_KEY=change-me-to-a-random-secret

# ---------------------------------------------------------------------------
# Ports
# ---------------------------------------------------------------------------

# Port to access the Musically web UI (Nginx listens on this port)
APP_PORT=8080

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------

# PostgreSQL password (used in production with the `db` service)
DB_PASSWORD=change-me

# Full database URL.
# Production (PostgreSQL via Docker service):
#   DATABASE_URL=postgresql+asyncpg://musically:${DB_PASSWORD}@db:5432/musically
# Development (SQLite file-based, no separate DB container needed):
#   DATABASE_URL=sqlite+aiosqlite:///./data/musically.db
#
# This is auto-set in docker-compose.yml / override; uncomment to override.
# DATABASE_URL=postgresql+asyncpg://musically:yourpassword@db:5432/musically

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------

# Redis connection URL (broker for Celery + cache)
REDIS_URL=redis://redis:6379/0

# ---------------------------------------------------------------------------
# File Paths (inside containers)
# ---------------------------------------------------------------------------

# Root music directory (mounted from NAS in production)
MUSIC_DIR=/music

# Temporary staging for Qobuz downloads before beets processes them
DOWNLOADS_DIR=/downloads

# Application config directory (beets config, app settings)
CONFIG_DIR=/config

# ---------------------------------------------------------------------------
# Qobuz — Music Download Source
# ---------------------------------------------------------------------------

# Your Qobuz account credentials (required for downloading)
QOBUZ_EMAIL=your-qobuz-email@example.com
QOBUZ_PASSWORD=your-qobuz-password

# ---------------------------------------------------------------------------
# LastFM — Listening History
# ---------------------------------------------------------------------------

# LastFM API credentials. Get them at: https://www.last.fm/api/account/create
LASTFM_API_KEY=your-lastfm-api-key
LASTFM_API_SECRET=your-lastfm-api-secret

# Your LastFM username to poll for recent tracks
LASTFM_USERNAME=your-lastfm-username

# ---------------------------------------------------------------------------
# Spotify — Playlist Integration
# ---------------------------------------------------------------------------

# Spotify API credentials. Get them at: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret

# OAuth redirect URI (must match your Spotify app settings)
SPOTIFY_REDIRECT_URI=http://localhost:8080/api/v1/auth/spotify/callback

# ---------------------------------------------------------------------------
# Discord — Notifications
# ---------------------------------------------------------------------------

# Discord webhook URL for download notifications.
# Create one at: Server Settings → Integrations → Webhooks
DISCORD_WEBHOOK_URL=

# ---------------------------------------------------------------------------
# MusicBrainz (Optional)
# ---------------------------------------------------------------------------

# MusicBrainz is used via beets internally.
# No API key is required, but you can set a custom server if needed.
# MUSICBRAINZ_HOST=https://musicbrainz.org

# ---------------------------------------------------------------------------
# Rule Engine (Optional — defaults shown)
# ---------------------------------------------------------------------------

# Cron expression for the rule engine sync cycle.
# Default: every 30 minutes
# RULE_ENGINE_CRON=*/30 * * * *

# Queue stall retry intervals (hours, comma-separated).
# Default: 24,72,168,336 (1 day, 3 days, 7 days, 14 days)
# RETRY_INTERVAL_HOURS=24,72,168,336
